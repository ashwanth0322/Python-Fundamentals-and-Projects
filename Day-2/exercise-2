#Convert the mark into grade
def grade(mark):
    if mark > 90:
        return "A+"
    elif mark > 80:
        return "A"
    elif mark > 70:
        return "B"
    elif mark > 60:
        return "C"
    elif mark < 61:
        return "Fail"   
    
A=grade(98)
print(A)
B=grade(75)
print(B)
c=grade(40)
print(c)


